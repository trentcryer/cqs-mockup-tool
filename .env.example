# ============================================
# CQS Mockup Studio - Environment Variables
# Copy this to .env and fill in your values.
# The Next.js app and legacy Python tool both load from this file.
# ============================================

# --- Printful (required for catalog + mockups) ---
PRINTFUL_API_KEY=your_printful_api_key_here

# --- Supabase (required for auth, DB, storage) ---
# Get from https://supabase.com/dashboard/project/_/settings/api
# Note: Supabase now uses "Publishable key" (anon) and "Secret key" (service_role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ versions are required for client-side Supabase auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Secret key - ONLY for server-side admin operations (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend (for "Request Review" email alerts to Trent) ---
# Get free key at https://resend.com
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL="CQS Mockup Studio <studio@yourdomain.com>"
# Where review requests are sent (Trent's email)
TRENT_EMAIL=trent@example.com

# --- Shopify Admin API (for admin "push to store" feature) ---
# Create a custom app in your Shopify Admin > Settings > Apps > Develop apps
# Grant: write_products, read_products
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_admin_token
SHOPIFY_API_VERSION=2024-10

# --- Tawk.to live chat widget (optional) ---
# Both ids come from the embed URL tawk gives you:
#   https://embed.tawk.to/<PROPERTY_ID>/<WIDGET_ID>
# The chat bubble only renders when BOTH are set. Branding (name, photo,
# colors) is configured in the tawk dashboard, not in code.
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# --- Optional / future ---
# For Shopify customer sync (optional handoff)
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=...
# For rate limiting / production
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Note: Only PRINTFUL_API_KEY was present in the original Streamlit tool.
# All new keys are additive and backward compatible.